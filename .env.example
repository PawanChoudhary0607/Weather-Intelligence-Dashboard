# Copy this file to .env and fill in values as needed.
# The application runs fully without any of these set, since Open-Meteo
# (the primary weather provider) requires no API key.

# Only required if you want to exercise the OpenWeatherMap fallback path.
# Get a free key at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# Optional: override the port the application listens on.
PORT=8080
